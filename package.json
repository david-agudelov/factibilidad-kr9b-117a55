{
  "name": "three-gsap-tailwind-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "rag:download": "node rag/scripts/downloadSources.ts",
    "rag:prepare:text": "node rag/scripts/prepareTextCorpus.ts",
    "rag:prepare:spatial": "node rag/scripts/prepareSpatialCorpus.ts",
    "rag:build:spatial-facts": "node rag/scripts/buildKr9bSpatialFacts.ts",
    "rag:prepare": "npm run rag:download && npm run rag:prepare:text && npm run rag:prepare:spatial",
    "rag:evaluate": "node rag/scripts/evaluateRag.ts",
    "rag:evaluate:normative": "node rag/scripts/evaluateRag.ts --category normative",
    "rag:evaluate:spatial": "node rag/scripts/evaluateRag.ts --category spatial",
    "cf:build:data": "node rag/scripts/buildWorkerData.ts",
    "cf:dev": "wrangler dev --config cloudflare-worker/wrangler.jsonc",
    "cf:deploy": "wrangler deploy --config cloudflare-worker/wrangler.jsonc",
    "cf:ingest": "node rag/scripts/ingestCloudflareVectorize.ts",
    "cf:test": "vitest run cloudflare-worker"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}

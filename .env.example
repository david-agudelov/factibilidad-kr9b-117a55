# Factibilidad Live Modeler
# Copy this file to .env.local when local overrides are needed.

VITE_APP_NAME="Factibilidad Live Modeler"
VITE_APP_CASE_ID="KR9B_117A55"
VITE_APP_LOCALE="es-CO"
VITE_APP_UNITS="metric"
VITE_ENABLE_ECOS_MODE="true"
VITE_RAG_ENABLED="true"
VITE_RAG_ENDPOINT="/api/normative-chat"

# Server-only RAG variables. Never expose these with VITE_*.
# OPENAI_API_KEY="sk-..."
# OPENAI_VECTOR_STORE_ID="vs_..."
# RAG_MODEL="gpt-4.1-mini"
# RAG_SOURCE_MANIFEST_PATH="data/rag/manifest/sources.manifest.json"
# RAG_SPATIAL_FACTS_PATH="data/spatial/facts"

# Cloudflare Worker local testing. Copy cloudflare-worker/.dev.vars.example to
# cloudflare-worker/.dev.vars for Worker-only variables. Never put server
# secrets in VITE_* variables.
